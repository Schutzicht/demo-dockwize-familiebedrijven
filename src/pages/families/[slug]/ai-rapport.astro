---
import AppLayout from '../../../layouts/AppLayout.astro';
import Card from '../../../components/Card.astro';
import ScoreBadge from '../../../components/ScoreBadge.astro';
import FamilyTabs from '../../../components/FamilyTabs.astro';
import { allFamilies } from '../../../data/wattel';
import { CATEGORY_DEFINITIONS } from '../../../data/types';

export function getStaticPaths() {
  return allFamilies.map((f) => ({ params: { slug: f.slug } }));
}

const family = allFamilies.find((f) => f.slug === Astro.params.slug);
if (!family) return Astro.redirect('/families');

const latest = family.aiReports[family.aiReports.length - 1];
const categoryById = new Map(CATEGORY_DEFINITIONS.map((c) => [c.id, c]));

const sourceEntries = latest
  ? family.logfile.filter((e) => latest.logEntryIds.includes(e.id) && !e.isBeginNote)
  : [];
const excludedBegin = family.logfile.filter((e) => e.isBeginNote).length;
---

<AppLayout
  title={`AI-rapport — ${family.name}`}
  topbarTitle={family.name}
  topbarSubtitle="AI-gegenereerd conceptrapport uit logfile-bevindingen"
>
  <FamilyTabs family={family} active="ai-rapport" />

  <div class="mx-auto max-w-7xl space-y-6 px-6 py-8">
    <Card padding="lg" class="overflow-hidden">
      <div class="grid items-start gap-6 lg:grid-cols-3">
        <div class="lg:col-span-2">
          <p class="text-[11px] uppercase tracking-widest text-[var(--color-ink-3)]">Automatisering #3</p>
          <h2 class="mt-1 text-[22px] font-semibold tracking-tight">AI-rapport genereren</h2>
          <p class="mt-2 text-[13px] text-[var(--color-ink-2)] leading-relaxed">
            Bundelt alle <strong>logfile-bevindingen</strong> die niet als begin-aantekening zijn gemarkeerd, samen met de antwoorden uit KO en WS1, en maakt per categorie een concept van <em>Risico&apos;s &amp; aandachtspunten</em> en <em>Advies</em>. Adviseurs kunnen dit aanscherpen en gebruiken ter voorbereiding van de volgende sessie.
          </p>
          <div class="mt-5 flex flex-wrap items-center gap-3">
            <button
              id="generate-btn"
              class="inline-flex items-center gap-2 rounded-[10px] bg-[var(--color-accent)] px-4 py-2.5 text-[13px] font-semibold text-[var(--color-ink)] transition hover:brightness-95"
            >
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 3l1.9 5.8H20l-4.9 3.6 1.9 5.8L12 14.6l-5 3.6 1.9-5.8L4 8.8h6.1z"/>
              </svg>
              Genereer AI-rapport
            </button>
            <button class="inline-flex items-center gap-1.5 rounded-[10px] border border-[var(--color-border)] bg-[var(--color-surface)] px-3 py-2 text-[12.5px] font-medium text-[var(--color-ink-2)] hover:border-[var(--color-border-strong)]">
              <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M7 10l5 5 5-5M12 15V3"/></svg>
              Download als PDF
            </button>
          </div>
        </div>
        <div class="rounded-[10px] bg-[var(--color-surface-2)] p-4 text-[12px]">
          <p class="text-[10.5px] uppercase tracking-widest text-[var(--color-muted)]">Bronmateriaal</p>
          <ul class="mt-3 space-y-2">
            <li class="flex items-center justify-between"><span>KO antwoorden</span><span class="font-medium tabular-nums">{family.questionnaires.find((q) => q.moment === 'KO')?.answers.length ?? 0}</span></li>
            <li class="flex items-center justify-between"><span>WS1 antwoorden</span><span class="font-medium tabular-nums">{family.questionnaires.find((q) => q.moment === 'WS1')?.answers.length ?? 0}</span></li>
            <li class="flex items-center justify-between"><span>Logfile-notities</span><span class="font-medium tabular-nums">{family.logfile.length}</span></li>
            <li class="flex items-center justify-between text-[var(--color-ink-3)]"><span>– waarvan &quot;begin&quot; (uitgesloten)</span><span class="tabular-nums">{excludedBegin}</span></li>
          </ul>
        </div>
      </div>
    </Card>

    <div id="generating" class="hidden">
      <Card padding="lg">
        <div class="flex items-center gap-4">
          <div class="h-10 w-10 animate-spin rounded-full border-2 border-[var(--color-border)] border-t-[var(--color-ink)]"></div>
          <div>
            <p class="text-[14px] font-semibold">AI analyseert bronnen…</p>
            <p class="text-[12px] text-[var(--color-ink-3)]" id="generating-step">Logfile-notities laden</p>
          </div>
        </div>
        <div class="mt-4 h-1.5 overflow-hidden rounded-full bg-[var(--color-surface-2)]">
          <div id="generating-bar" class="h-full w-0 bg-[var(--color-accent)] transition-all duration-300"></div>
        </div>
      </Card>
    </div>

    {latest && (
      <Card padding="none">
        <div class="flex items-center justify-between border-b border-[var(--color-border)] px-5 py-4">
          <div>
            <p class="text-[11px] uppercase tracking-widest text-[var(--color-ink-3)]">Laatste rapport</p>
            <h3 class="text-[15px] font-semibold tracking-tight">Gegenereerd op {latest.generatedAt}</h3>
            <p class="text-[12px] text-[var(--color-ink-3)]">door {latest.generatedBy} · bronnen: {latest.sourceMomentsConsidered.join(', ')} + {sourceEntries.length} logfile-notities (excl. begin)</p>
          </div>
          <span class="inline-flex items-center gap-1.5 rounded-full bg-[var(--color-accent-soft)] px-3 py-1 text-[11px] font-medium text-[var(--color-ink)]">
            <svg class="h-3 w-3" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l2.4 7.2L22 12l-7.6 2.8L12 22l-2.4-7.2L2 12l7.6-2.8z"/></svg>
            AI-concept
          </span>
        </div>

        <div class="border-b border-[var(--color-border)] bg-[var(--color-surface-2)]/40 px-5 py-4">
          <p class="text-[11px] uppercase tracking-widest text-[var(--color-muted)]">Samenvatting</p>
          <p class="mt-2 text-[13px] leading-relaxed text-[var(--color-ink)]">{latest.summary}</p>
        </div>

        <div class="divide-y divide-[var(--color-border)]/60">
          {latest.perCategory.map((p) => {
            const cat = categoryById.get(p.categoryId)!;
            return (
              <div class="grid gap-4 px-5 py-5 lg:grid-cols-12">
                <div class="lg:col-span-3">
                  <div class="flex items-center gap-2">
                    <span class="flex h-7 w-7 items-center justify-center rounded-full bg-[var(--color-ink)] text-[11px] font-semibold text-white">{p.categoryId}</span>
                    <h4 class="text-[13.5px] font-semibold">{cat.title}</h4>
                  </div>
                  <div class="mt-2">
                    <ScoreBadge score={p.proposedScore} size="sm" label={`AI voorstel: ${p.proposedScore}`} />
                  </div>
                </div>
                <div class="lg:col-span-5">
                  <p class="text-[10.5px] uppercase tracking-widest text-[var(--color-muted)]">Risico&apos;s &amp; aandachtspunten</p>
                  <p class="mt-1.5 text-[12.5px] leading-relaxed text-[var(--color-ink)]">{p.risicos}</p>
                </div>
                <div class="lg:col-span-4">
                  <p class="text-[10.5px] uppercase tracking-widest text-[var(--color-muted)]">Advies</p>
                  <p class="mt-1.5 text-[12.5px] leading-relaxed text-[var(--color-ink)]">{p.advies}</p>
                </div>
              </div>
            );
          })}
        </div>

        <div class="flex items-center justify-between border-t border-[var(--color-border)] bg-[var(--color-surface-2)]/40 px-5 py-4">
          <p class="text-[12px] text-[var(--color-ink-3)]">Tevreden met de concept-tekst? Verwerk in de team-beoordeling.</p>
          <a href={`/families/${family.slug}/team-beoordeling`} class="inline-flex items-center gap-1.5 rounded-[10px] bg-[var(--color-ink)] px-3 py-2 text-[12.5px] font-medium text-white hover:bg-black">
            Naar team-beoordeling
            <svg class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
          </a>
        </div>
      </Card>
    )}

    {family.aiReports.length > 1 && (
      <Card padding="md">
        <h3 class="text-[14px] font-semibold tracking-tight">Eerdere AI-rapporten</h3>
        <ul class="mt-3 divide-y divide-[var(--color-border)]/60">
          {family.aiReports.slice(0, -1).reverse().map((r) => (
            <li class="flex items-center justify-between py-2 text-[12.5px]">
              <span><span class="font-medium">{r.generatedAt}</span> · {r.generatedBy}</span>
              <a href="#" class="text-[var(--color-ink-2)] hover:text-[var(--color-ink)]">Bekijken →</a>
            </li>
          ))}
        </ul>
      </Card>
    )}
  </div>

  <script>
    const btn = document.getElementById('generate-btn');
    const wrap = document.getElementById('generating');
    const bar = document.getElementById('generating-bar');
    const step = document.getElementById('generating-step');
    const steps = [
      'Logfile-notities laden',
      'KO en WS1 antwoorden inlezen',
      'Begin-aantekeningen uitsluiten',
      'Per categorie redeneren',
      'Conceptadvies formuleren',
      'Rapport opmaken',
    ];
    btn?.addEventListener('click', () => {
      if (!wrap || !bar || !step) return;
      wrap.classList.remove('hidden');
      btn.setAttribute('disabled', 'true');
      btn.classList.add('opacity-60', 'cursor-not-allowed');
      let i = 0;
      const tick = () => {
        if (i >= steps.length) {
          if (bar) bar.style.width = '100%';
          setTimeout(() => {
            wrap.classList.add('hidden');
            btn.removeAttribute('disabled');
            btn.classList.remove('opacity-60', 'cursor-not-allowed');
            window.scrollTo({ top: document.body.scrollHeight, behavior: 'smooth' });
          }, 500);
          return;
        }
        step.textContent = steps[i];
        bar.style.width = `${((i + 1) / steps.length) * 100}%`;
        i++;
        setTimeout(tick, 650);
      };
      tick();
    });
  </script>
</AppLayout>
