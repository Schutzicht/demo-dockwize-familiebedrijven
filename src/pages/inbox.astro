---
import AppLayout from '../layouts/AppLayout.astro';
import Card from '../components/Card.astro';

const notifications = [
  { id: 'n1', read: false, type: 'questionnaire', title: 'Sanne Wattel heeft de WS1-vragenlijst voltooid', when: '12 minuten geleden', family: 'Familie Wattel', href: '/families/wattel/vragenlijsten?m=WS1' },
  { id: 'n2', read: false, type: 'ai', title: 'AI-rapport gegenereerd voor Familie Wattel', when: '2 uur geleden', family: 'Familie Wattel', href: '/families/wattel/ai-rapport' },
  { id: 'n3', read: true, type: 'logfile', title: 'Pieter Poortvliet voegde een notitie toe bij categorie 4', when: 'gisteren', family: 'Familie Wattel', href: '/families/wattel/logfile' },
  { id: 'n4', read: true, type: 'questionnaire', title: 'Joost Wattel heeft de TK-vragenlijst voltooid', when: '5 dagen geleden', family: 'Familie Wattel', href: '/families/wattel/vragenlijsten?m=TK' },
  { id: 'n5', read: true, type: 'meeting', title: 'Eerste opvolgmoment Wattel ingepland', when: '1 week geleden', family: 'Familie Wattel', href: '/families/wattel' },
];

const iconMap: Record<string, string> = {
  questionnaire: 'M8 6h13M8 12h13M8 18h13M3 6h.01M3 12h.01M3 18h.01',
  ai: 'M12 3l1.9 5.8H20l-4.9 3.6 1.9 5.8L12 14.6l-5 3.6 1.9-5.8L4 8.8h6.1z',
  logfile: 'M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8l-6-6zm0 2v4h4',
  meeting: 'M19 4H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2zM16 2v4M8 2v4M3 10h18',
};

const unread = notifications.filter((n) => !n.read).length;
---

<AppLayout
  title="Inbox — Dockwize Familiebedrijven"
  topbarTitle="Inbox"
  topbarSubtitle={`${unread} ongelezen meldingen`}
>
  <Fragment slot="topbar-action">
    <button class="inline-flex items-center gap-1.5 rounded-[10px] border border-[var(--color-border)] bg-[var(--color-surface)] px-3 py-2 text-[12.5px] font-medium text-[var(--color-ink-2)] hover:border-[var(--color-border-strong)]">Markeer alles gelezen</button>
  </Fragment>

  <div class="mx-auto max-w-3xl space-y-4 px-6 py-8">
    <div class="flex gap-1">
      <button class="rounded-[8px] bg-[var(--color-ink)] px-3 py-1.5 text-[12px] font-medium text-white">Alle ({notifications.length})</button>
      <button class="rounded-[8px] bg-[var(--color-surface-2)] px-3 py-1.5 text-[12px] font-medium text-[var(--color-ink-2)] hover:bg-[var(--color-border)]">Ongelezen ({unread})</button>
    </div>

    <Card padding="none">
      <div class="divide-y divide-[var(--color-border)]/60">
        {notifications.map((n) => (
          <a href={n.href} class={`flex items-start gap-4 px-5 py-4 transition-colors hover:bg-[var(--color-surface-2)] ${n.read ? '' : 'bg-[var(--color-accent-soft)]/30'}`}>
            <span class={`mt-0.5 flex h-9 w-9 shrink-0 items-center justify-center rounded-[10px] ${n.read ? 'bg-[var(--color-surface-2)] text-[var(--color-ink-3)]' : 'bg-[var(--color-ink)] text-white'}`}>
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d={iconMap[n.type]}/></svg>
            </span>
            <div class="flex-1 min-w-0">
              <p class={`text-[13px] ${n.read ? 'text-[var(--color-ink-2)]' : 'font-semibold text-[var(--color-ink)]'}`}>{n.title}</p>
              <p class="mt-0.5 text-[11.5px] text-[var(--color-ink-3)]">{n.family} · {n.when}</p>
            </div>
            {!n.read && <span class="mt-2 h-2 w-2 shrink-0 rounded-full bg-[var(--color-accent)]"></span>}
          </a>
        ))}
      </div>
    </Card>
  </div>
</AppLayout>
