---
import AppLayout from '../layouts/AppLayout.astro';
import Card from '../components/Card.astro';
import ScoreBadge from '../components/ScoreBadge.astro';
import { allFamilies } from '../data/wattel';
import { CATEGORY_DEFINITIONS } from '../data/types';

const allReports = allFamilies.flatMap((f) => f.aiReports.map((r) => ({ family: f, report: r })));
const totalReports = allReports.length;
const lastReport = allReports[allReports.length - 1];
const categoryById = new Map(CATEGORY_DEFINITIONS.map((c) => [c.id, c]));
const subject = allFamilies[0];
---

<AppLayout
  title="AI-analyses — Dockwize Familiebedrijven"
  topbarTitle="AI-analyses"
  topbarSubtitle="Alle gegenereerde rapporten over alle families"
>
  <Fragment slot="topbar-action">
    <button id="new-analysis-btn" type="button" class="inline-flex items-center gap-2 rounded-[10px] bg-[var(--color-accent)] px-3 py-2 text-[12.5px] font-semibold text-[var(--color-ink)] transition hover:brightness-95">
      <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l1.9 5.8H20l-4.9 3.6 1.9 5.8L12 14.6l-5 3.6 1.9-5.8L4 8.8h6.1z"/></svg>
      Nieuwe analyse
    </button>
  </Fragment>

  <div class="mx-auto max-w-7xl space-y-6 px-6 py-8">
    <div class="grid gap-4 sm:grid-cols-3">
      <Card>
        <p class="text-[11px] uppercase tracking-widest text-[var(--color-ink-3)]">Rapporten gegenereerd</p>
        <p id="report-count" class="mt-2 text-3xl font-semibold tracking-tight">{totalReports}</p>
      </Card>
      <Card>
        <p class="text-[11px] uppercase tracking-widest text-[var(--color-ink-3)]">Laatste rapport</p>
        <p id="last-report-date" class="mt-2 text-[13px] font-medium">{lastReport?.report.generatedAt ?? '—'}</p>
        <p id="last-report-family" class="text-[11.5px] text-[var(--color-ink-3)]">{lastReport?.family.name}</p>
      </Card>
      <Card>
        <p class="text-[11px] uppercase tracking-widest text-[var(--color-ink-3)]">Model</p>
        <p class="mt-2 text-[13px] font-medium">Claude Opus 4.7</p>
        <p class="text-[11.5px] text-[var(--color-ink-3)]">Anthropic, prompt v2</p>
      </Card>
    </div>

    <Card padding="none">
      <div class="border-b border-[var(--color-border)] px-5 py-4">
        <h3 class="text-[14px] font-semibold tracking-tight">Recente analyses</h3>
        <p class="text-[12px] text-[var(--color-ink-3)]">Klik op een rapport voor het volledige overzicht in de familie-werkmap.</p>
      </div>
      <div id="recent-list" class="divide-y divide-[var(--color-border)]/60">
        {allReports.length === 0 && (
          <div class="px-5 py-12 text-center text-[13px] text-[var(--color-ink-3)]">Nog geen analyses gegenereerd.</div>
        )}
        {allReports.map(({ family, report }) => (
          <a href={`/families/${family.slug}/ai-rapport`} class="grid grid-cols-12 items-center gap-4 px-5 py-4 hover:bg-[var(--color-surface-2)]">
            <div class="col-span-3">
              <p class="text-[13px] font-semibold">{family.name}</p>
              <p class="text-[11.5px] text-[var(--color-ink-3)]">{family.business}</p>
            </div>
            <div class="col-span-3 text-[12px] text-[var(--color-ink-2)]">
              <p>{report.generatedAt}</p>
              <p class="text-[var(--color-ink-3)]">door {report.generatedBy}</p>
            </div>
            <div class="col-span-3 text-[12px] text-[var(--color-ink-2)]">
              <p>Bronnen: {report.sourceMomentsConsidered.join(', ')}</p>
              <p class="text-[var(--color-ink-3)]">{report.logEntryIds.length} logfile-notities</p>
            </div>
            <div class="col-span-3 flex flex-wrap justify-end gap-1">
              {report.perCategory.map((p) => <ScoreBadge score={p.proposedScore} size="sm" label={String(p.categoryId)} />)}
            </div>
          </a>
        ))}
      </div>
    </Card>

    {lastReport && (
      <Card padding="lg">
        <p class="text-[11px] uppercase tracking-widest text-[var(--color-ink-3)]">Laatste samenvatting</p>
        <h3 class="mt-1 text-[15px] font-semibold tracking-tight">{lastReport.family.name} — {lastReport.report.generatedAt}</h3>
        <p class="mt-3 text-[13px] leading-relaxed text-[var(--color-ink-2)]">{lastReport.report.summary}</p>
      </Card>
    )}
  </div>

  <!-- Dummy AI-analyse generator -->
  <div id="analysis-modal" class="fixed inset-0 z-[90] hidden" data-slug={subject.slug} data-name={subject.name}>
    <div id="analysis-backdrop" class="absolute inset-0 bg-[rgba(20,20,18,0.5)]"></div>
    <div class="absolute left-1/2 top-1/2 w-[440px] max-w-[calc(100vw-24px)] -translate-x-1/2 -translate-y-1/2 rounded-[18px] border border-[var(--color-border)] bg-[var(--color-surface)] shadow-[var(--shadow-lg)]">
      <div class="flex items-center justify-between border-b border-[var(--color-border)] px-5 py-4">
        <div class="flex items-center gap-2">
          <span class="flex h-7 w-7 items-center justify-center rounded-full bg-[var(--color-accent)] text-[var(--color-ink)]">
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l1.9 5.8H20l-4.9 3.6 1.9 5.8L12 14.6l-5 3.6 1.9-5.8L4 8.8h6.1z"/></svg>
          </span>
          <h3 class="text-[15px] font-semibold tracking-tight">Nieuwe AI-analyse</h3>
        </div>
        <button id="analysis-close" type="button" aria-label="Sluiten" class="flex h-7 w-7 items-center justify-center rounded-full text-[var(--color-ink-3)] transition-colors hover:bg-[var(--color-surface-2)] hover:text-[var(--color-ink)]">
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18M6 6l12 12"/></svg>
        </button>
      </div>

      <div id="analysis-config" class="px-5 py-5">
        <p class="text-[12.5px] text-[var(--color-ink-2)]">Genereer een conceptanalyse voor:</p>
        <div class="mt-2 rounded-[10px] border border-[var(--color-border)] bg-[var(--color-surface-2)] px-3 py-2.5">
          <p class="text-[13px] font-semibold">{subject.name}</p>
          <p class="text-[11.5px] text-[var(--color-ink-3)]">{subject.business}</p>
        </div>
        <p class="mt-4 text-[10.5px] uppercase tracking-widest text-[var(--color-muted)]">Bronnen</p>
        <div class="mt-2 space-y-1.5">
          {['KO-antwoorden', 'WS1-antwoorden', 'Logfile-notities (excl. begin)'].map((b) => (
            <div class="flex items-center gap-2 text-[12.5px] text-[var(--color-ink-2)]">
              <span class="flex h-4 w-4 items-center justify-center rounded-[5px] bg-[var(--color-ink)] text-white">
                <svg class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
              </span>
              {b}
            </div>
          ))}
        </div>
        <div class="mt-5 flex justify-end gap-2">
          <button type="button" class="analysis-cancel rounded-[9px] border border-[var(--color-border)] bg-[var(--color-surface)] px-3 py-1.5 text-[12.5px] font-medium text-[var(--color-ink-2)] transition-colors hover:border-[var(--color-border-strong)]">Annuleren</button>
          <button id="analysis-start" type="button" class="rounded-[9px] bg-[var(--color-accent)] px-3.5 py-1.5 text-[12.5px] font-semibold text-[var(--color-ink)] transition hover:brightness-95">Start analyse</button>
        </div>
      </div>

      <div id="analysis-running" class="hidden px-5 py-6">
        <div class="flex items-center gap-3">
          <div class="h-9 w-9 animate-spin rounded-full border-2 border-[var(--color-border)] border-t-[var(--color-ink)]"></div>
          <div>
            <p class="text-[13.5px] font-semibold">AI analyseert bronnen…</p>
            <p id="analysis-step" class="text-[12px] text-[var(--color-ink-3)]">Logfile-notities laden</p>
          </div>
        </div>
        <div class="mt-4 h-1.5 overflow-hidden rounded-full bg-[var(--color-surface-2)]">
          <div id="analysis-bar" class="h-full w-0 bg-[var(--color-accent)] transition-all duration-300"></div>
        </div>
      </div>

      <div id="analysis-done" class="hidden px-5 py-5">
        <div class="flex items-center gap-2">
          <span class="flex h-7 w-7 items-center justify-center rounded-full bg-[var(--color-score-green-soft)] text-[var(--color-score-green)]">
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
          </span>
          <h4 class="text-[14px] font-semibold tracking-tight">Analyse voltooid</h4>
        </div>
        <p id="analysis-summary" class="mt-3 text-[12.5px] leading-relaxed text-[var(--color-ink-2)]"></p>
        <div id="analysis-badges" class="mt-3 flex flex-wrap gap-1"></div>
        <div class="mt-5 flex justify-end gap-2">
          <button type="button" class="analysis-cancel rounded-[9px] border border-[var(--color-border)] bg-[var(--color-surface)] px-3 py-1.5 text-[12.5px] font-medium text-[var(--color-ink-2)] transition-colors hover:border-[var(--color-border-strong)]">Sluiten</button>
          <a id="analysis-view" href={`/families/${subject.slug}/ai-rapport`} class="rounded-[9px] bg-[var(--color-ink)] px-3.5 py-1.5 text-[12.5px] font-semibold text-white transition-colors hover:bg-black">Bekijk rapport</a>
        </div>
      </div>
    </div>
  </div>

  <script>
    const modal = document.getElementById('analysis-modal');
    const btn = document.getElementById('new-analysis-btn');
    if (modal && btn) {
      const backdrop = document.getElementById('analysis-backdrop');
      const closeBtn = document.getElementById('analysis-close');
      const cancels = modal.querySelectorAll('.analysis-cancel');
      const stConfig = document.getElementById('analysis-config');
      const stRunning = document.getElementById('analysis-running');
      const stDone = document.getElementById('analysis-done');
      const startBtn = document.getElementById('analysis-start');
      const stepEl = document.getElementById('analysis-step');
      const barEl = document.getElementById('analysis-bar');
      const summaryEl = document.getElementById('analysis-summary');
      const badgesEl = document.getElementById('analysis-badges');
      const list = document.getElementById('recent-list');
      const countEl = document.getElementById('report-count');
      const lastDateEl = document.getElementById('last-report-date');
      const lastFamEl = document.getElementById('last-report-family');

      const slug = modal.dataset.slug || '';
      const famName = modal.dataset.name || 'Familie';

      const steps = [
        'Logfile-notities laden',
        'KO en WS1 antwoorden inlezen',
        'Begin-aantekeningen uitsluiten',
        'Per categorie redeneren',
        'Knelpunt-codes toewijzen',
        'Conceptadvies formuleren',
        'Rapport opmaken',
      ];
      const summaries = [
        'Op koers met enkele aandachtspunten. De familieafspraken en de financiering vragen om verdere uitwerking; de opvolgers zijn bekwaam en gemotiveerd.',
        'Het traject staat er goed voor. Aandacht is nodig voor de waardering en de strategische onderbouwing richting de bank. Proces en regie zijn helder.',
        'Sterke basis met een paar openstaande punten rond financiën en governance. Een vervolgafspraak om de afspraken vast te leggen is aan te raden.',
      ];

      const BADGE: Record<string, string> = {
        green: 'bg-[var(--color-score-green-soft)] text-[var(--color-score-green)]',
        yellow: 'bg-[var(--color-score-yellow-soft)] text-[var(--color-score-yellow)]',
        red: 'bg-[var(--color-score-red-soft)] text-[var(--color-score-red)]',
      };
      const DOT: Record<string, string> = {
        green: 'bg-[var(--color-score-green)]',
        yellow: 'bg-[var(--color-score-yellow)]',
        red: 'bg-[var(--color-score-red)]',
      };
      const rollScore = (): string => {
        const r = Math.random();
        return r < 0.45 ? 'green' : r < 0.82 ? 'yellow' : 'red';
      };
      const badgeHtml = (score: string, label: string) =>
        `<span class="inline-flex items-center gap-1.5 rounded-full px-2 py-0.5 text-[10px] font-medium ${BADGE[score]}"><span class="h-1.5 w-1.5 rounded-full ${DOT[score]}"></span>${label}</span>`;

      const show = (el: Element | null) => el && el.classList.remove('hidden');
      const hide = (el: Element | null) => el && el.classList.add('hidden');

      const setState = (state: Element | null) => {
        hide(stConfig); hide(stRunning); hide(stDone);
        show(state);
      };
      const open = () => { modal.classList.remove('hidden'); setState(stConfig); };
      const close = () => { modal.classList.add('hidden'); setState(stConfig); if (barEl) barEl.style.width = '0%'; };

      btn.addEventListener('click', open);
      closeBtn?.addEventListener('click', close);
      cancels.forEach((c) => c.addEventListener('click', close));
      backdrop?.addEventListener('click', () => { if (!stRunning?.classList.contains('hidden')) return; close(); });

      const finish = () => {
        const scores = Array.from({ length: 9 }, () => rollScore());
        const today = new Date().toLocaleDateString('nl-NL', { day: 'numeric', month: 'long', year: 'numeric' });

        if (summaryEl) summaryEl.textContent = summaries[Math.floor(Math.random() * summaries.length)];
        if (badgesEl) badgesEl.innerHTML = scores.map((s, i) => badgeHtml(s, String(i + 1))).join('');
        setState(stDone);

        // Werk de pagina bij zodat het lijkt alsof er echt iets is gegenereerd
        if (countEl) countEl.textContent = String((parseInt(countEl.textContent || '0', 10) || 0) + 1);
        if (lastDateEl) lastDateEl.textContent = today;
        if (lastFamEl) lastFamEl.textContent = famName;
        if (list) {
          const row = document.createElement('a');
          row.href = `/families/${slug}/ai-rapport`;
          row.className = 'grid grid-cols-12 items-center gap-4 px-5 py-4 hover:bg-[var(--color-surface-2)]';
          row.innerHTML =
            `<div class="col-span-3"><p class="text-[13px] font-semibold">${famName}</p><p class="text-[11.5px] text-[var(--color-ink-3)]">zojuist gegenereerd</p></div>` +
            `<div class="col-span-3 text-[12px] text-[var(--color-ink-2)]"><p>${today}</p><p class="text-[var(--color-ink-3)]">door Imro Wong</p></div>` +
            `<div class="col-span-3 text-[12px] text-[var(--color-ink-2)]"><p>Bronnen: KO, WS1</p><p class="text-[var(--color-ink-3)]">11 logfile-notities</p></div>` +
            `<div class="col-span-3 flex flex-wrap justify-end gap-1">${scores.map((s, i) => badgeHtml(s, String(i + 1))).join('')}</div>`;
          const empty = list.querySelector('.py-12');
          if (empty) empty.remove();
          list.prepend(row);
        }
      };

      startBtn?.addEventListener('click', () => {
        setState(stRunning);
        if (barEl) barEl.style.width = '0%';
        let i = 0;
        const tick = () => {
          if (i >= steps.length) { if (barEl) barEl.style.width = '100%'; setTimeout(finish, 450); return; }
          if (stepEl) stepEl.textContent = steps[i];
          if (barEl) barEl.style.width = `${((i + 1) / steps.length) * 100}%`;
          i++;
          setTimeout(tick, 600);
        };
        tick();
      });
    }
  </script>
</AppLayout>
