---
import type { Family } from '../data/types';

interface Props {
  family: Family;
  active: 'overzicht' | 'vragenlijsten' | 'logfile' | 'ai-rapport' | 'team-beoordeling' | 'eindrapport' | 'klantview';
}
const { family, active } = Astro.props;

const tabs = [
  { id: 'overzicht', label: 'Overzicht', href: `/families/${family.slug}` },
  { id: 'vragenlijsten', label: 'Vragenlijsten', href: `/families/${family.slug}/vragenlijsten` },
  { id: 'logfile', label: 'Logfile', href: `/families/${family.slug}/logfile` },
  { id: 'ai-rapport', label: 'AI-rapport', href: `/families/${family.slug}/ai-rapport` },
  { id: 'team-beoordeling', label: 'Team-beoordeling', href: `/families/${family.slug}/team-beoordeling` },
];
---

<div data-tour="tabs" class="border-b border-[var(--color-border)] bg-[var(--color-surface)]">
  <div class="flex items-center gap-1 overflow-x-auto px-5 scrollbar-hide">
    {tabs.map((t) => {
      const isActive = t.id === active;
      return (
        <a
          href={t.href}
          class={`relative whitespace-nowrap px-3 py-3 text-[13px] font-medium transition-colors ${
            isActive
              ? 'text-[var(--color-ink)]'
              : 'text-[var(--color-ink-3)] hover:text-[var(--color-ink)]'
          }`}
        >
          {t.label}
          {isActive && (
            <span class="absolute inset-x-3 -bottom-px h-0.5 bg-[var(--color-ink)]"></span>
          )}
        </a>
      );
    })}
  </div>
</div>
