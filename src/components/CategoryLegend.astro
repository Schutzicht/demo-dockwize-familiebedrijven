---
import { CATEGORY_DEFINITIONS } from '../data/types';

interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
---

<div class={`flex flex-wrap items-center justify-center gap-x-4 gap-y-2.5 ${className}`}>
  {CATEGORY_DEFINITIONS.map((c) => (
    <span class="inline-flex items-center gap-1.5 text-[11.5px] text-[var(--color-ink-2)]">
      <span class="flex h-[18px] w-[18px] shrink-0 items-center justify-center rounded-full bg-[var(--color-ink)] text-[9.5px] font-bold text-white">{c.id}</span>
      {c.shortTitle}
    </span>
  ))}
</div>
