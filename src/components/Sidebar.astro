---
import DockwizeMark from './DockwizeMark.astro';

interface NavItem {
  label: string;
  href: string;
  iconPath: string;
  badge?: string | number;
}
interface NavGroup {
  label?: string;
  items: NavItem[];
}

// Lucide-icoonlichamen (24x24, stroke). Gerenderd via set:html in een gedeelde <svg>.
const icons = {
  dashboard:
    '<rect width="7" height="9" x="3" y="3" rx="1"/><rect width="7" height="5" x="14" y="3" rx="1"/><rect width="7" height="9" x="14" y="12" rx="1"/><rect width="7" height="5" x="3" y="16" rx="1"/>',
  building:
    '<path d="M6 22V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v18Z"/><path d="M6 12H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h2"/><path d="M18 9h2a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2h-2"/><path d="M10 6h4"/><path d="M10 10h4"/><path d="M10 14h4"/><path d="M10 18h4"/>',
  list:
    '<rect width="8" height="4" x="8" y="2" rx="1" ry="1"/><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><path d="M12 11h4"/><path d="M12 16h4"/><path d="M8 11h.01"/><path d="M8 16h.01"/>',
  sparkles:
    '<path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .962 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.962 0z"/><path d="M20 3v4"/><path d="M22 5h-4"/><path d="M4 17v2"/><path d="M5 18H3"/>',
  library: '<path d="m16 6 4 14"/><path d="M12 6v14"/><path d="M8 8v12"/><path d="M4 4v16"/>',
  upload: '<path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" x2="12" y1="3" y2="15"/>',
  users:
    '<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>',
  settings:
    '<path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"/><circle cx="12" cy="12" r="3"/>',
  inbox:
    '<polyline points="22 12 16 12 14 15 10 15 8 12 2 12"/><path d="M5.45 5.11 2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6l-3.45-6.89A2 2 0 0 0 16.76 4H7.24a2 2 0 0 0-1.79 1.11z"/>',
};

const groups: NavGroup[] = [
  {
    items: [
      { label: 'Overzicht', href: '/', iconPath: icons.dashboard },
      { label: 'Families', href: '/families', iconPath: icons.building, badge: 3 },
      { label: 'Vragenlijsten', href: '/vragenlijsten', iconPath: icons.list },
      { label: 'Kleurplaat', href: '/import', iconPath: icons.upload, badge: 'MVP' },
      { label: 'AI-analyses', href: '/ai', iconPath: icons.sparkles, badge: 'AI' },
      { label: 'Bibliotheek', href: '/bibliotheek', iconPath: icons.library },
    ],
  },
  {
    label: 'Beheer',
    items: [
      { label: 'Team', href: '/team', iconPath: icons.users },
      { label: 'Inbox', href: '/inbox', iconPath: icons.inbox, badge: 2 },
      { label: 'Instellingen', href: '/instellingen', iconPath: icons.settings },
    ],
  },
];

const pathname = Astro.url.pathname;
const isActive = (href: string) =>
  pathname === href || (href !== '/' && pathname.startsWith(href));
---

<aside
  data-pinned="false"
  class="dw-sidebar hidden h-screen shrink-0 flex-col overflow-hidden border-r border-[var(--color-border)] bg-[var(--color-surface)] md:flex"
>
  <div class="flex h-14 items-center border-b border-[var(--color-border)]">
    <a href="/" aria-label="Dockwize Familiebedrijven" class="flex h-14 items-center gap-2.5">
      <span class="flex w-16 items-center justify-center">
        <DockwizeMark size={28} />
      </span>
      <span class="dw-sidebar-fade flex flex-col leading-none">
        <span class="text-[16px] font-semibold tracking-tight text-[var(--color-ink)]">Dockwize</span>
        <span class="mt-1 text-[10px] font-medium uppercase tracking-[0.14em] text-[var(--color-ink-3)]">Familiebedrijven</span>
      </span>
    </a>
  </div>

  <nav class="flex-1 overflow-y-auto overflow-x-hidden p-2">
    {groups.map((group, gi) => (
      <div class={gi > 0 ? 'mt-4' : ''}>
        {group.label && (
          <p class="dw-sidebar-fade px-2.5 pb-1.5 text-[10.5px] font-medium uppercase tracking-[0.08em] text-[var(--color-muted)]">
            {group.label}
          </p>
        )}
        <ul class="space-y-0.5">
          {group.items.map((item) => {
            const active = isActive(item.href);
            return (
              <li>
                <a
                  href={item.href}
                  title={item.label}
                  class={`group relative flex items-center gap-2.5 overflow-hidden rounded-[8px] px-2.5 py-2 text-[13px] font-medium transition-all ${
                    active
                      ? 'bg-[var(--color-ink)] text-white shadow-[var(--shadow-sm)]'
                      : 'text-[var(--color-ink-2)] hover:bg-[var(--color-surface-2)] hover:text-[var(--color-ink)]'
                  }`}
                >
                  <svg
                    class={`h-[18px] w-[18px] shrink-0 ${active ? 'text-white' : 'text-[var(--color-ink-3)] group-hover:text-[var(--color-ink-2)]'}`}
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.85"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    set:html={item.iconPath}
                  />
                  <span class="dw-sidebar-fade flex-1 truncate">{item.label}</span>
                  {item.badge !== undefined && (
                    <span class={`dw-sidebar-fade inline-flex h-5 min-w-5 items-center justify-center rounded-full px-1.5 text-[10px] font-semibold ${
                      typeof item.badge === 'string'
                        ? 'bg-[var(--color-accent)] text-[var(--color-ink)]'
                        : active
                          ? 'bg-white/20 text-white'
                          : 'bg-[var(--color-surface-2)] text-[var(--color-ink-2)]'
                    }`}>
                      {item.badge}
                    </span>
                  )}
                </a>
              </li>
            );
          })}
        </ul>
      </div>
    ))}
  </nav>

  <div class="border-t border-[var(--color-border)] p-2">
    <button
      id="dw-sidebar-pin"
      type="button"
      class="flex w-full items-center gap-2.5 overflow-hidden rounded-[8px] px-2.5 py-1.5 text-[12px] font-medium transition-colors text-[var(--color-ink-3)] hover:bg-[var(--color-surface-2)] hover:text-[var(--color-ink)]"
      title="Sidebar vastpinnen"
    >
      <svg class="h-4 w-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.85" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 17v5"/><path d="M9 10.76a2 2 0 0 1-1.11 1.79l-1.78.9A2 2 0 0 0 5 15.24V16a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-.76a2 2 0 0 0-1.11-1.79l-1.78-.9A2 2 0 0 1 15 10.76V7a1 1 0 0 1 1-1 2 2 0 0 0 0-4H8a2 2 0 0 0 0 4 1 1 0 0 1 1 1z"/>
      </svg>
      <span class="dw-sidebar-fade" id="dw-pin-label">Vastpinnen</span>
    </button>
  </div>
</aside>

<script>
  const KEY = 'dockwize_sidebar_pinned';
  const aside = document.querySelector<HTMLElement>('.dw-sidebar');
  const btn = document.getElementById('dw-sidebar-pin');
  const lbl = document.getElementById('dw-pin-label');
  const stored = typeof localStorage !== 'undefined' && localStorage.getItem(KEY) === '1';
  if (aside) aside.dataset.pinned = stored ? 'true' : 'false';
  if (lbl) lbl.textContent = stored ? 'Loslaten' : 'Vastpinnen';
  btn?.addEventListener('click', () => {
    if (!aside) return;
    const next = aside.dataset.pinned !== 'true';
    aside.dataset.pinned = next ? 'true' : 'false';
    localStorage.setItem(KEY, next ? '1' : '0');
    if (lbl) lbl.textContent = next ? 'Loslaten' : 'Vastpinnen';
  });
</script>
