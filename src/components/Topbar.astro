---
interface Props {
  title?: string;
  subtitle?: string;
}
const { title, subtitle } = Astro.props;
---

<header class="glass sticky top-0 z-30 flex h-14 items-center justify-between border-b border-[var(--color-border)] px-5">
  <div class="flex min-w-0 flex-1 items-center gap-4">
    {title && (
      <div class="min-w-0">
        <h1 class="truncate text-[15px] font-semibold tracking-tight text-[var(--color-ink)]">{title}</h1>
        {subtitle && <p class="truncate text-[11.5px] text-[var(--color-ink-3)]">{subtitle}</p>}
      </div>
    )}
  </div>

  <div class="flex items-center gap-3">
    <div class="relative hidden md:block">
      <svg class="pointer-events-none absolute left-3 top-1/2 h-3.5 w-3.5 -translate-y-1/2 text-[var(--color-muted)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
      </svg>
      <input
        type="text"
        placeholder="Zoek families, vragen, notities…"
        class="h-9 w-[280px] rounded-[10px] border border-[var(--color-border)] bg-[var(--color-surface-2)] pl-9 pr-12 text-[13px] outline-none transition focus:border-[var(--color-border-strong)] focus:bg-[var(--color-surface)]"
      />
      <kbd class="pointer-events-none absolute right-2 top-1/2 hidden -translate-y-1/2 rounded border border-[var(--color-border)] bg-[var(--color-surface)] px-1.5 py-0.5 text-[10px] font-mono text-[var(--color-muted)] md:inline-block">⌘K</kbd>
    </div>

    <slot name="action" />

    <button
      type="button"
      data-dw-tour-start
      class="inline-flex h-9 items-center gap-1.5 rounded-[10px] border border-[var(--color-border)] bg-[var(--color-surface)] px-3 text-[12.5px] font-medium text-[var(--color-ink-2)] transition-all hover:border-[var(--color-border-strong)] hover:text-[var(--color-ink)]"
    >
      <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/></svg>
      <span class="hidden sm:inline">Rondleiding</span>
    </button>

    <button class="relative flex h-9 w-9 items-center justify-center rounded-[10px] border border-[var(--color-border)] bg-[var(--color-surface)] text-[var(--color-ink-2)] transition-all hover:border-[var(--color-border-strong)] hover:text-[var(--color-ink)]">
      <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"/><path d="M10.3 21a1.94 1.94 0 0 0 3.4 0"/>
      </svg>
      <span class="absolute -right-1 -top-1 flex h-4 w-4 items-center justify-center rounded-full bg-[var(--color-danger)] text-[9px] font-semibold text-white">2</span>
    </button>

    <div class="flex items-center gap-2 rounded-[10px] border border-[var(--color-border)] bg-[var(--color-surface)] py-1 pl-1 pr-2.5 text-[12px]">
      <span class="flex h-7 w-7 items-center justify-center rounded-md bg-[var(--color-ink)] text-[11px] font-semibold text-white">IW</span>
      <div class="hidden flex-col leading-none sm:flex">
        <span class="font-medium text-[var(--color-ink)]">Imro Wong</span>
        <span class="mt-0.5 text-[10px] uppercase tracking-wider text-[var(--color-ink-3)]">Projectleider</span>
      </div>
    </div>
  </div>
</header>
