---
// Globale toast. Gebruik window.dwToast('bericht') of data-toast="bericht" op een knop.
---

<div id="dw-toast-wrap" class="pointer-events-none fixed bottom-4 right-4 z-[110] flex flex-col items-end gap-2"></div>

<script>
  function makeToast(message: string) {
    const wrap = document.getElementById('dw-toast-wrap');
    if (!wrap) return;
    const t = document.createElement('div');
    t.className =
      'pointer-events-auto flex items-center gap-2 rounded-[10px] bg-[var(--color-ink)] px-3.5 py-2.5 text-[12.5px] font-medium text-white shadow-[var(--shadow-lg)] translate-y-1 opacity-0 transition-all duration-200';
    t.innerHTML =
      '<svg class="h-4 w-4 shrink-0 text-[var(--color-accent)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg><span></span>';
    const span = t.querySelector('span');
    if (span) span.textContent = message;
    wrap.appendChild(t);
    requestAnimationFrame(() => t.classList.remove('translate-y-1', 'opacity-0'));
    setTimeout(() => {
      t.classList.add('opacity-0');
      setTimeout(() => t.remove(), 250);
    }, 2600);
  }

  (window as unknown as { dwToast: (m: string) => void }).dwToast = makeToast;

  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement | null;
    const el = target?.closest('[data-toast]');
    if (el) makeToast(el.getAttribute('data-toast') || 'Gereed');
  });
</script>
